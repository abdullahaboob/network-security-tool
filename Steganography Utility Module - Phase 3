def create_test_image(path: str, size: int = 300):
    """Create a simple cover image for testing."""
    import random
    img = Image.new("RGB", (size, size))
    pixels = [(random.randint(0, 255),
               random.randint(0, 255),
               random.randint(0, 255)) for _ in range(size * size)]
    img.putdata(pixels)
    img.save(path, format="PNG")
    print(f"  [STEG] Test image created: {path} ({size}x{size} px)")


