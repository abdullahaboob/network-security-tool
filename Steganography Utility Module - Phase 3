import sys
import os
from PIL import Image
from Crypto.Cipher import AES
from Crypto.Random import get_random_bytes


# ============================================================
# AES-GCM helpers (same pattern as secure_scanner)
# ============================================================

def _aes_encrypt_bytes(data: bytes, key: bytes) -> bytes:
    """Encrypt bytes with AES-GCM. Returns nonce(16)+tag(16)+ciphertext."""
    nonce = get_random_bytes(16)
    cipher = AES.new(key, AES.MODE_GCM, nonce=nonce)
    ciphertext, tag = cipher.encrypt_and_digest(data)
    return nonce + tag + ciphertext

def _aes_decrypt_bytes(data: bytes, key: bytes) -> bytes:
    """Decrypt AES-GCM blob produced by _aes_encrypt_bytes."""
    nonce      = data[:16]
    tag        = data[16:32]
    ciphertext = data[32:]
    cipher = AES.new(key, AES.MODE_GCM, nonce=nonce)
    return cipher.decrypt_and_verify(ciphertext, tag)


# ============================================================
# LSB Steganography Core
# ============================================================

DELIMITER = b"##STEG_END##"   # marks end of hidden payload

def _bits_from_bytes(data: bytes):
    """Yield each bit (0 or 1) of a bytes object, MSB first."""
    for byte in data:
        for i in range(7, -1, -1):
            yield (byte >> i) & 1

def _bytes_from_bits(bits):
    """Reconstruct bytes from an iterable of bits."""
    result = bytearray()
    for i in range(0, len(bits), 8):
        byte = 0
        for b in bits[i:i + 8]:
            byte = (byte << 1) | b
        result.append(byte)
    return bytes(result)


def hide_text(image_path: str, secret_text: str, output_path: str,
              encrypt: bool = False, key: bytes = None):
    """
    Hide secret_text inside image using 1-bit LSB steganography.
    """
    img = Image.open(image_path).convert("RGB")
    pixels = list(img.getdata())

    payload = secret_text.encode("utf-8")
    if encrypt:
        if key is None or len(key) != 32:
            raise ValueError("AES key must be exactly 32 bytes.")
        payload = _aes_encrypt_bytes(payload, key)
        print(f"  [STEG] Payload encrypted ({len(payload)} bytes after encryption)")

    payload += DELIMITER   # append end marker
    bits = list(_bits_from_bytes(payload))

    # capacity check
    capacity_bits = len(pixels) * 3   # 1 bit per channel
    if len(bits) > capacity_bits:
        raise ValueError(
            f"Image too small! Need {len(bits)} bits, have {capacity_bits}.")

    # embed bits into LSB of each channel
    new_pixels = []
    bit_idx = 0
    for r, g, b in pixels:
        if bit_idx < len(bits):
            r = (r & ~1) | bits[bit_idx];     bit_idx += 1
        if bit_idx < len(bits):
            g = (g & ~1) | bits[bit_idx];     bit_idx += 1
        if bit_idx < len(bits):
            b = (b & ~1) | bits[bit_idx];     bit_idx += 1
        new_pixels.append((r, g, b))

    stego = Image.new("RGB", img.size)
    stego.putdata(new_pixels)
    stego.save(output_path, format="PNG")
    print(f"  [STEG] Hidden {len(secret_text)} chars in '{output_path}'")
    print(f"  [STEG] Capacity used: {len(bits)}/{capacity_bits} bits "
          f"({100*len(bits)/capacity_bits:.2f}%)")


def extract_text(stego_path: str, decrypt: bool = False,
                 key: bytes = None) -> str:
    """
    Extract hidden text from stego image.
    """
    img = Image.open(stego_path).convert("RGB")
    pixels = list(img.getdata())

    bits = []
    for r, g, b in pixels:
        bits.extend([r & 1, g & 1, b & 1])

    raw = _bytes_from_bits(bits)

    # find delimiter
    idx = raw.find(DELIMITER)
    if idx == -1:
        raise ValueError("No hidden payload found (delimiter not detected).")

    payload = raw[:idx]

    if decrypt:
        if key is None or len(key) != 32:
            raise ValueError("AES key must be exactly 32 bytes.")
        payload = _aes_decrypt_bytes(payload, key)
        print("  [STEG] Payload decrypted successfully.")

    return payload.decode("utf-8")


